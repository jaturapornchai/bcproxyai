# SMLGateway — Environment Variables
#
# **API Keys are stored in the database (api_keys table) — set them via Setup modal in dashboard.**
# This file only contains non-secret runtime config.
#
# cp .env.example .env.local

# ── Optional runtime config ──

# Ollama local URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloudflare account ID — used to construct AI inference URL
# (the API token still goes in DB via Setup modal)
CLOUDFLARE_ACCOUNT_ID=

# Database (defaults work with docker-compose; override only if running outside compose)
# DATABASE_URL=postgres://sml:smlpass@localhost:5434/smlgateway
# REDIS_URL=redis://localhost:6382
