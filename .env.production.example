# SMLGateway production env — copy to .env.production on the droplet.
# DO NOT commit the real .env.production file.

# === Master Bearer key ===
# Clients send `Authorization: Bearer <key>` via OpenAI SDK.
# Generate: node -e "console.log('sk-gw-' + require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_API_KEY=sk-gw-<generate-with-node-crypto-randomBytes-32-hex>

# === Admin identity ===
# Owner email(s) — Google-login admins. Comma-separated.
AUTH_OWNER_EMAIL=jaturapornchai@gmail.com,teammate@gmail.com

# === Admin login options (at least one recommended) ===

# (A) Google OAuth — optional but preferred for audit trail.
#     Add callback {NEXTAUTH_URL}/api/auth/callback/google on Google Console.
NEXTAUTH_URL=https://your-domain.example.com
NEXTAUTH_SECRET=<generate-with-node-crypto-randomBytes-32-base64>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# (B) Password login — for admins without a Google account / airgap access.
#     Mints a signed httpOnly cookie valid 7 days. Rate-limited.
#     Pick ≥ 20 random chars. Empty = password path disabled.
ADMIN_PASSWORD=<generate-with-node-crypto-randomBytes-24-base64>

# === Provider keys (managed from dashboard /setup, NOT env) ===
# Leave empty. Gateway reads provider API keys from the `api_keys` DB
# table populated by the Setup modal.

# === Cost policy ===
# Default production mode must not spend provider quota/money.
# Provider allowlist is for trusted local/no-key providers only.
# Cloud providers must use model-level free rules, e.g. OpenRouter `*:free`.
# Do not add Together here if the account has billable credit.
SML_FREE_PROVIDER_ALLOWLIST=ollama,pollinations
SML_FREE_MODEL_ALLOWLIST=openrouter/*:free,openrouter/openrouter/free
# SML_ALLOW_PAID_PROVIDERS=0
